Conditions: {
	HasJustice: Requires JUSTICE soul trait
	HasKindness: Requires KINDNESS soul trait
	HasBravery: Requires BRAVERY soul trait
	HasPatience: Requires PATIENCE soul trait
	HasIntegrity: Requires INTEGRITY soul trait
	HasPerseverance: Requires PERSEVERANCE soul trait
	HasDetermination: Requires DETERMINATION soul trait
}
