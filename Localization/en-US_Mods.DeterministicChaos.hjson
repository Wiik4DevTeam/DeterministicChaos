		DisplayName: Dark Bullet
		Tooltip:
			'''
			A shell that hungers for violence.
			Attaches to enemies on hit.
			When 10 bullets attach within 2 seconds, they explode.
			'''
	}

	RoaringTome: {
		DisplayName: Clarity
		Tooltip:
			'''
			A book with no knowledge to gleam, but consequence.
			Fires piercing star projectiles that cost no mana.
			Right click to release a slow, powerful orb that absorbs stars, at the cost of all your mana.
			The orb grows in size, speed, and damage with each absorbed star.
			'''
