	RoaringHelmet: {
		DisplayName: Roaring Helmet
		Tooltip:
			'''
			Your wrath cuts deeper than the shadows.
			+10% melee attack speed.
			'''
	}

	RoaringMask: {
		DisplayName: Roaring Mask
		Tooltip:
