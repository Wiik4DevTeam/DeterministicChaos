			'''
	}

	Cascade: {
		DisplayName: Cascade
		Tooltip:
			'''
			A crossbow of immense destructive power.
			Converts all arrows into a high-velocity bolt that sticks to any surface or enemy.
			The bolt pulls nearby enemies toward it, then detonates for massive damage.
			While attached, it calls in 8 copies of the loaded arrows from afar.
			Consumes 3 arrows per shot.
			'''
	}

	ShatteredGlass: {
		DisplayName: Shattered Glass
		Tooltip:
			'''
			Fires a deep blue beam of fractured light.
			Hits create glass shards around enemies for a short time.
			Further hits ricochet between the shards for extra damage.
			'''
	}

	Leyline: {
		DisplayName: Leyline
		Tooltip:
			'''
			A whip that behaves like a living grapple.
			Hooks to enemies or the cursor and reels you in over time.
			Enemies touching the tether take repeated damage.
			Release while latched onto an enemy to deal up to 10x damage.
			This release damage maxes out after 2 seconds attached.
			'''
	}

	TitansArrow: {
		DisplayName: Titan's Arrow
		Tooltip:
			'''
			Sticks to the first target or surface it hits.
			Deals 20% damage on impact, then explodes for the remaining 80% after 1 second.
			'''
	}

	Appendage: {
		DisplayName: Appendage
		Tooltip:
			'''
			The Titan's grasp, now yours to command.
			Summons two Titan hands that flank you.
			The hands periodically fire devastating lasers at nearby enemies.
			Whip-tagged targets are prioritized.
			Takes up two minion slots. Only one pair may be summoned.
			'''
