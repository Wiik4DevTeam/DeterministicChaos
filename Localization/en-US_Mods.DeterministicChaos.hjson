		Breakdown: (Armor: {0} | Weapon: {1} | Potion: {2})
		Active: "[Active]"
		Points: "[{0} pts]"
	}

	TitanForgeItem: {
		DisplayName: Titan Forge
		Tooltip: A workbench forged from dark energy, used to craft powerful items. Can occasionaly be found in a Dark World.
	}
}

