		Tooltip:
			'''
			"Is it a 1, or an 11?"
			Converts Musket Balls into piercing Spade projectiles
			Spades can pierce up to three enemies
			'''
	}

	QueenOfDiamonds: {
		DisplayName: Queen of Diamonds
		Tooltip:
			'''
			"She'll beat you if she's able."
			Whip hits command your minions to attack
			Each minion fires a diamond at the struck target
			Up to 5 diamonds per hit
			'''
	}

	KingOfHearts: {
		DisplayName: King of Hearts
		Tooltip:
			'''
			"Off with their heads!"
			Hold to summon orbiting hearts, up to 10
			Hearts cost 25 mana each
			Release to send the heart swarm toward the cursor
			'''
	}

	DeckOfCards: {
		DisplayName: Deck of Cards
		Tooltip:
			'''
			+0.5 luck
			+4% critical strike chance
			Hitting enemies creates a card over your head
			At 5 cards, unleash a suit attack based on your poker hand
			The 'Luck' stat improves chances at better hands
			Cards can only be gained once per second
			'''
	}

	OopsAllCrits: {
		DisplayName: Oops All Crits
		Tooltip:
			'''
			+0.15 luck
			+45% critical strike chance
			-22% total damage
			'''
	}

	JackOfClubs: {
		DisplayName: Jack of Clubs
		Tooltip:
			'''
			"Hit the road."
			Slam the ground to create a shockwave of clubs
			Direct hits launch enemies into the air
			Its immense weight carries you along with it
			'''
	}

	Cascade: {
		DisplayName: Cascade
		Tooltip:
			'''
			A crossbow of immense destructive power.
			Converts all arrows into a high-velocity bolt that sticks to any surface or enemy.
			The bolt pulls nearby enemies toward it, then detonates for massive damage.
			While attached, it calls in 8 copies of the loaded arrows from afar.
			Consumes 3 arrows per shot.
			'''
	}

	ShatteredGlass: {
		DisplayName: Shattered Glass
		Tooltip:
			'''
			Fires a deep blue beam of fractured light.
			Hits create glass shards around enemies for a short time.
			Further hits ricochet between the shards for extra damage.
			'''
	}

	Leyline: {
		DisplayName: Leyline
		Tooltip:
			'''
			A whip that behaves like a living grapple.
			Hooks to enemies or the cursor and reels you in over time.
			Enemies touching the tether take repeated damage.
			Release while latched onto an enemy to deal up to 10x damage.
			This release damage maxes out after 2 seconds attached.
			'''
	}

	TitansArrow: {
		DisplayName: Titan's Arrow
		Tooltip:
			'''
			Sticks to the first target or surface it hits.
			Deals 20% damage on impact, then explodes for the remaining 80% after 1 second.
			'''
	}

	Appendage: {
		DisplayName: Appendage
		Tooltip:
			'''
			The Titan's grasp, now yours to command.
			Summons two Titan hands that flank you.
			The hands periodically fire devastating lasers at nearby enemies.
			Whip-tagged targets are prioritized.
			Takes up two minion slots. Only one pair may be summoned.
			'''
	}

	TitanicEmblem: {
		DisplayName: Titanic Emblem
		Tooltip:
			'''
			The weight of a Titan behind every swing.
			112% increased true melee weapon size.
			10% increased true melee weapon damage.
			66% increased true melee weapon knockback.
			25% decreased true melee weapon attack speed.
			'''
	}

	TitanStar: {
		DisplayName: Titan Star
		Tooltip: Summons a radiant star to light your way.
	}
}

Tiles: {
	DarkPortal.MapEntry: Dark Portal
	TitanForge.MapEntry: Titan Forge
}

SoulTraits: {
	Justice: {
		Name: JUSTICE
		Description: A soul that seeks fairness and truth.
		Bonus3: Gain a built-in triple jump.
		Bonus5: Increased critical strike chance by 6%.
		Bonus12: Increased projectile damage by 10%.
		Bonus20: Every 5 hits, gain a Justice Mark. \nYour next hit is guaranteed to critically strike.
	}

	Kindness: {
		Name: KINDNESS
		Description: A soul that nurtures and protects.
		Bonus3: +2 life regeneration to you. Heals nearby allies and town NPCs for 2 HP every second.
		Bonus5: When you or nearby allies take damage, increase your defense by +6 for 3 seconds.
		Bonus12: Potion effects are applied to nearby allies. +20% potion effect duration.
		Bonus20: When you or an ally dies, you and each ally gain a Kindness Mark. Increases total damage by 25% for 10 seconds.
	}

	Bravery: {
		Name: BRAVERY
		Description: A soul that charges forward without fear.
		Bonus3: +10% global damage to enemies within 10 tiles. Take 5% increased damage.
		Bonus5: +20% move speed while in combat.
		Bonus12: Taking damage increases damage dealt by 12% for 6 seconds.
		Bonus20: After dealing damage, gain a Bravery Mark. Increases global attack speed up to 20% based on enemy proximity.
	}

	Patience: {
		Name: PATIENCE
		Description: A soul that waits for the perfect moment.
		Bonus3: Enemies are less likely to target you.
		Bonus5: Gain double life regen speed while not moving.
		Bonus12: Gain access to Rogue Stealth. If you already have Rogue Stealth, increases maximum by 30.
		Bonus20: Every 30 seconds without taking damage, gain a Patience Mark. The next hit consumes the stack to reduce damage by 50%.
	}

	Integrity: {
		Name: INTEGRITY
		Description: A soul that stays true to one's self.
		Bonus3: +20% increased defense. -10% total damage dealt.
		Bonus5: Taking damage increases your damage dealt by 5%. Lasts 5 seconds, stacks up to 5 times.
		Bonus12: Removes all negative effects from previous investment bonuses.
		Bonus20: After taking damage, gain an Integrity Mark. Your next hit will add your Defense as flat bonus damage.
	}

	Perseverance: {
		Name: PERSEVERANCE
		Description: A soul that endures through hardship.
		Bonus3: Health pickups also restore mana. Mana pickups also restore health.
		Bonus5: +1% damage for each buff and debuff active on you.
		Bonus12: Gain up to +50 max health based on current mana, and +50 max mana based on current health.
		Bonus20: At full health, gain a Perseverance Mark. The next hit consumes the mark to deal 50% less damage, but depletes all mana.
	}

	Determination: {
		Name: DETERMINATION
		Description: A soul that refuses to give up.
		Bonus3: Reduced respawn time by 5 seconds.
		Bonus5: 6% increased global damage.
		Bonus12: Increased immunity frames when taking damage.
		Bonus20: At 50% health, gain a Determination Mark and store your position. On death, revive at half health and return to that position. 2 minute cooldown.
	}

	UI: {
		NoTrait: No Soul Trait
		VisitGerson: Visit Gerson to obtain a Soul Trait
		Locked: "[Locked - Hardmode]"
		InvestmentPoints: Investment Points: {0}/20
		Breakdown: (Armor: {0} | Weapon: {1} | Potion: {2})
		Active: "[Active]"
		Points: "[{0} pts]"
	}

	TitanForgeItem: {
		DisplayName: Titan Forge
		Tooltip: A workbench forged from dark energy, used to craft powerful items. Can occasionaly be found in a Dark World.
	}
}

